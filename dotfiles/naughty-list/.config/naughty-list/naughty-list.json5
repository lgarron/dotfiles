{
  "$schema": "https://raw.githubusercontent.com/lgarron/naughty-list/44e8a279d266950f310edef10ad56b6dfb5c46eb/src/schema.json",
  "trashCommandPrefix": [
    "/usr/bin/trash"
  ],
  "paths": {
    "ignore": [
      ".cache",
      ".CFUserTextEncoding",
      ".config",
      ".data",
      ".dropbox", // TODO: Pythagoras-only 😡
      ".DS_Store", // *sigh*
      ".hushlogin", // TODO: Pythagoras-only
      ".local",
      ".ssh",
      ".state",
      ".Trash",
      ".vscode", // grrrrrr: https://github.com/microsoft/vscode/issues/3884
    ],
    "delete": [
      ".angular-config.json",
      ".biome",
      ".bun_repl_history", // bun 😭 https://github.com/oven-sh/bun/issues/28291
      ".bundle", // Ruby Gems
      ".cargo",
      ".cups",
      ".docker",
      ".dts",
      ".gem", // Ruby Gems
      ".gk",
      ".gnupg",
      ".gradle", // Gradle (Java)
      ".hugindata",
      ".lldb",
      ".m2", // Maven (Java)
      ".npm",
      ".obsidian-cli.sock",
      ".oracle_jre_usage",
      ".pnpm-state",
      ".profile", // Created by `rustup`
      ".python_history",
      ".rnd",
      ".rustup",
      ".sentry ",
      ".step",
      ".swiftpm",
      ".terraform.d",
      ".thumbnails", // Blender (among others)
      ".vscode-cli",
      ".vscode-remote-containers",
      ".vscode-server",
      ".vscode-shared",
      ".wasmer",
      ".yarn",
      ".yarnrc",
      // Flutter
      ".dart-tool",
      ".dart",
      ".flutter-devtools",
      ".flutter",
      ".pub-cache",
      // CrossOver?
      ".mailcap",
      ".mime.types",
    ]
  }
}
